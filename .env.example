# Copy to .env and fill in values. .env is gitignored.

# Census ACS5 API key — required by Checkpoint 2/H2_Pipeline/01_acquire_data.py
# (poverty rate, median household income, population per ZCTA).
# Get one free at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Gemini API key — used by agentic_pipeline/agents.py (not needed for the
# Checkpoint 3 deterministic pipeline).
GEMINI_API_KEY=
